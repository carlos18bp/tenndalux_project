[Unit]
Description=Huey Task Queue for tenndalux
After=network.target redis.service

[Service]
Type=simple
User=ryzepeck
Group=www-data
WorkingDirectory=/home/ryzepeck/webapps/tenndalux_project/backend
ExecStart=/home/ryzepeck/webapps/tenndalux_project/backend/venv/bin/python manage.py run_huey --workers 1
Environment="DJANGO_SETTINGS_MODULE=core_project.settings"
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
